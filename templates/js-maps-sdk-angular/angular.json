{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "js-maps-sdk-angular-template": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/styles.css"],
            "loader": {
              ".woff2": "file"
            },
            "allowedCommonJsDependencies": [
              "core-js",
              "@babel/runtime/regenerator",
              "raf",
              "rgbcolor",
              "ajv",
              "fastq",
              "fast-memoize",
              "html2canvas",
              "jszip",
              "pdfmake/build/pdfmake.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "9MB",
                  "maximumError": "12MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "extractLicenses": false
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "js-maps-sdk-angular-template:build:production"
            },
            "development": {
              "buildTarget": "js-maps-sdk-angular-template:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
